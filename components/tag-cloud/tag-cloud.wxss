/* ===== 标签云组件 v2 ===== */

.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 10rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 24rpx;
  border-radius: 12rpx;
  background: var(--primary-light, #FDF2F1);
  color: var(--primary, #D4574E);
  font-weight: 600;
  transition: all 0.2s ease;
}

.tag-item:active {
  transform: scale(0.95);
}

.tag-item.high {
  background: linear-gradient(135deg, var(--primary, #D4574E) 0%, var(--primary-dark, #B8433B) 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(212, 87, 78, 0.2);
}

.tag-item.medium {
  background: var(--primary-light, #FDF2F1);
  color: var(--primary, #D4574E);
}

.tag-item.low {
  background: var(--input-bg, #FAFAF8);
  color: var(--text-muted, #B5B0AB);
}

.tag-count {
  font-size: 20rpx;
  opacity: 0.7;
  margin-left: 4rpx;
  font-weight: 500;
}
