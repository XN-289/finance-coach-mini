/* ===== 迷你图表组件 v2 ===== */

.mini-chart {
  background: var(--card-bg, #fff);
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 42, 38, 0.05);
}

.chart-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text, #2D2A26);
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--primary, #D4574E);
}

/* 柱状图 */
.bar-chart {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.bar-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.bar-label {
  font-size: 22rpx;
  color: var(--text-secondary, #8A8580);
  width: 80rpx;
  text-align: right;
  font-weight: 500;
}

.bar-track {
  flex: 1;
  height: 22rpx;
  background: var(--divider, #F3EFEC);
  border-radius: 11rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 11rpx;
  transition: width 0.6s ease;
  min-width: 6rpx;
}

.bar-value {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text, #2D2A26);
  width: 60rpx;
  text-align: right;
}

/* 趋势图 */
.trend-chart {
  display: flex;
  flex-direction: column;
}

.trend-bars {
  display: flex;
  align-items: flex-end;
  gap: 10rpx;
  height: 200rpx;
  padding-bottom: 12rpx;
}

.trend-bar {
  flex: 1;
  min-height: 8rpx;
  border-radius: 6rpx 6rpx 0 0;
  position: relative;
  transition: height 0.5s ease;
}

.trend-tooltip {
  position: absolute;
  top: -36rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18rpx;
  color: var(--text-secondary, #8A8580);
  white-space: nowrap;
  font-weight: 600;
}

.trend-labels {
  display: flex;
  gap: 10rpx;
}

.trend-label {
  flex: 1;
  text-align: center;
  font-size: 18rpx;
  color: var(--text-muted, #B5B0AB);
  margin-top: 10rpx;
  font-weight: 500;
}

/* 环形图 */
.ring-chart {
  display: flex;
  justify-content: center;
  padding: 24rpx 0;
}

.ring-outer {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  position: relative;
}

.ring-fill {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.ring-inner {
  position: absolute;
  top: 22rpx;
  left: 22rpx;
  right: 22rpx;
  bottom: 22rpx;
  background: var(--card-bg, #fff);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ring-value {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text, #2D2A26);
}

.ring-label {
  font-size: 20rpx;
  color: var(--text-muted, #B5B0AB);
  margin-top: 4rpx;
  font-weight: 500;
}
