/* ===== 统计卡片组件 v2 ===== */

.stat-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: var(--card-bg, #fff);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 42, 38, 0.05);
  position: relative;
  transition: all 0.2s ease;
}

.stat-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(45, 42, 38, 0.03);
}

.stat-card.mini {
  padding: 20rpx;
}

.stat-card.up .stat-value { color: var(--up, #D4574E); }
.stat-card.down .stat-value { color: var(--down, #5BA870); }

.stat-icon {
  font-size: 42rpx;
  margin-right: 22rpx;
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-light, #FDF2F1);
  border-radius: 18rpx;
}

.stat-card.mini .stat-icon {
  width: 60rpx;
  height: 60rpx;
  font-size: 34rpx;
  margin-right: 18rpx;
  border-radius: 14rpx;
}

.stat-body {
  flex: 1;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text, #2D2A26);
  line-height: 1.2;
}

.stat-card.mini .stat-value {
  font-size: 34rpx;
}

.stat-unit {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--text-muted, #B5B0AB);
  margin-left: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-muted, #B5B0AB);
  margin-top: 8rpx;
  font-weight: 500;
}

.stat-card.mini .stat-label {
  font-size: 22rpx;
}

.stat-badge {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  background: var(--primary-light, #FDF2F1);
  color: var(--primary, #D4574E);
  font-weight: 600;
}
