/* ===== 交易教练 — 全局设计系统 ===== */

/* CSS 变量（亮色主题默认） */
page {
  --bg: #f5f6f8;
  --card-bg: #ffffff;
  --text: #1a1a1a;
  --text-secondary: #666666;
  --text-muted: #999999;
  --primary: #e4393c;
  --primary-light: #fef0f0;
  --primary-dark: #c1272d;
  --border: #e8e8e8;
  --divider: #f0f0f0;
  --input-bg: #fafafa;
  --shadow: rgba(0, 0, 0, 0.04);
  --success: #52c41a;
  --warning: #faad14;
  --danger: #ff4d4f;
  --info: #1890ff;
  --up: #e4393c;
  --down: #52c41a;

  background-color: var(--bg);
  height: 100%;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
}

/* ===== 公共容器 ===== */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: var(--bg);
}

.content-area {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 140rpx;
}

/* ===== 顶部导航栏 ===== */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: var(--primary);
}

.back-btn {
  font-size: 36rpx;
  color: #fff;
  padding: 0 10rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.space {
  width: 36rpx;
}

/* ===== 区块通用样式 ===== */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid var(--primary);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.review-section, .ai-section {
  background: var(--card-bg);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 1rpx 4rpx var(--shadow);
}

.review-text, .ai-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

/* ===== 底部按钮栏 ===== */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background-color: var(--card-bg);
  border-top: 1rpx solid var(--border);
  /* 适配 tabBar 页面 */
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: var(--primary);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 8rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  opacity: 0.85;
}

/* ===== 标签 ===== */
.draft-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  background-color: var(--primary);
  color: #fff;
  font-size: 20rpx;
  border-radius: 4rpx;
  margin-left: 16rpx;
}

/* ===== 空状态提示 ===== */
.empty-tip {
  text-align: center;
  padding: 40rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}

/* ===== 加载动画 ===== */
.loading {
  text-align: center;
  padding: 80rpx;
  color: var(--text-muted);
  font-size: 28rpx;
  background: var(--card-bg);
  border-radius: 12rpx;
  margin: 20rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0f0f0;
  border-top: 4rpx solid var(--primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* ===== 错误状态 ===== */
.error-section {
  background: var(--card-bg);
  border-radius: 12rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.error-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
  display: block;
}

.error-text {
  font-size: 28rpx;
  color: var(--primary);
  margin-bottom: 30rpx;
  display: block;
}

.retry-btn {
  background: var(--primary);
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

.retry-btn::after {
  border: none;
}

/* ===== 通用按钮 ===== */
.copy-btn {
  font-size: 24rpx;
  color: var(--primary);
  padding: 8rpx 16rpx;
  background: var(--primary-light);
  border-radius: 8rpx;
}

.action-btn {
  font-size: 24rpx;
  color: var(--primary);
}

.action-btn.delete {
  color: var(--text-muted);
}

/* ===== 通用卡片 ===== */
.card {
  background: var(--card-bg);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 1rpx 4rpx var(--shadow);
}

/* ===== 通用 Badge ===== */
.badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.badge.success { background: #f0fff0; color: var(--success); }
.badge.warning { background: #fffbe6; color: var(--warning); }
.badge.danger { background: #fff2f0; color: var(--danger); }
.badge.info { background: #e6f7ff; color: var(--info); }

/* ===== 通用按钮样式 ===== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.btn::after { border: none; }

.btn.primary { background: var(--primary); color: #fff; }
.btn.primary:active { opacity: 0.85; }

.btn.outline {
  background: transparent;
  color: var(--primary);
  border: 1rpx solid var(--primary);
}

.btn.ghost {
  background: transparent;
  color: var(--text-secondary);
}

.btn.small {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
}

/* ===== 通用输入框 ===== */
.input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background-color: var(--input-bg);
  border: 1rpx solid var(--border);
  border-radius: 8rpx;
  font-size: 28rpx;
  color: var(--text);
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 24rpx;
  background-color: var(--input-bg);
  border: 1rpx solid var(--border);
  border-radius: 8rpx;
  font-size: 28rpx;
  color: var(--text);
  box-sizing: border-box;
}

/* ===== 股票涨跌颜色 ===== */
.up { color: var(--up) !important; }
.down { color: var(--down) !important; }
.flat { color: var(--text-muted) !important; }

/* ===== 安全区域适配 ===== */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 渐变背景 ===== */
.gradient-primary {
  background: linear-gradient(135deg, #e4393c 0%, #c1272d 100%);
}

/* ===== 动画 ===== */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideInRight {
  from { transform: translateX(100%); }
  to { transform: translateX(0); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.animate-fadeIn { animation: fadeIn 0.3s ease; }
.animate-pulse { animation: pulse 2s infinite; }

/* ===== 深色模式适配（通过 class 切换） ===== */
/* 注意：WeChat 小程序不支持 CSS @media (prefers-color-scheme)
   深色模式通过页面根元素 class 控制 */
