/* 同花顺风格全局样式 — 红白简约 */
page {
  background-color: #f5f6f8;
  height: 100%;
}

/* ===== 公共容器 ===== */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f6f8;
}

.content-area {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 140rpx;
}

/* ===== 顶部导航栏 ===== */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #e4393c;
}

.back-btn {
  font-size: 36rpx;
  color: #fff;
  padding: 0 10rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.space {
  width: 36rpx;
}

/* ===== 区块通用样式 ===== */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #e4393c;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.review-section, .ai-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.review-text, .ai-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

/* ===== 底部按钮栏 ===== */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background-color: #fff;
  border-top: 1rpx solid #e8e8e8;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #e4393c;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 8rpx;
}

.submit-btn::after {
  border: none;
}

/* ===== 标签 ===== */
.draft-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  background-color: #e4393c;
  color: #fff;
  font-size: 20rpx;
  border-radius: 4rpx;
  margin-left: 16rpx;
}

/* ===== 空状态提示 ===== */
.empty-tip {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* ===== 加载动画 ===== */
.loading {
  text-align: center;
  padding: 80rpx;
  color: #999;
  font-size: 28rpx;
  background: #fff;
  border-radius: 12rpx;
  margin: 20rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0f0f0;
  border-top: 4rpx solid #e4393c;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* ===== 错误状态 ===== */
.error-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.error-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
  display: block;
}

.error-text {
  font-size: 28rpx;
  color: #e4393c;
  margin-bottom: 30rpx;
  display: block;
}

.retry-btn {
  background: #e4393c;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

.retry-btn::after {
  border: none;
}

/* ===== 通用按钮 ===== */
.copy-btn {
  font-size: 24rpx;
  color: #e4393c;
  padding: 8rpx 16rpx;
  background: #fef0f0;
  border-radius: 8rpx;
}

.action-btn {
  font-size: 24rpx;
  color: #e4393c;
}

.action-btn.delete {
  color: #999;
}
