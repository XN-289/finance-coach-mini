/* ===== 个人中心 v2 — 淡雅暖色设计 ===== */

.profile-scroll {
  height: 100vh;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 44rpx 32rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  margin: 24rpx;
  border-radius: 20rpx;
  color: #fff;
  box-shadow: 0 8rpx 28rpx rgba(212, 87, 78, 0.3);
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 54rpx;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  margin-right: 28rpx;
  backdrop-filter: blur(10px);
  border: 2rpx solid rgba(255,255,255,0.3);
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.user-name {
  font-size: 38rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.user-motto {
  font-size: 24rpx;
  opacity: 0.85;
  letter-spacing: 0.5rpx;
}

/* 快捷统计 */
.quick-stats {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  margin: 0 24rpx 20rpx;
  padding: 32rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 42, 38, 0.05);
}

.qs-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qs-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--primary);
  line-height: 1.2;
}

.qs-label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  font-weight: 500;
}

.qs-divider {
  width: 1rpx;
  height: 56rpx;
  background: var(--divider);
}

/* 交易画像 */
.profile-card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 0 24rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 42, 38, 0.05);
  border-left: 6rpx solid var(--info);
}

.profile-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 16rpx;
}

.profile-style {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 16rpx;
}

.profile-tags {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.profile-tag-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

.profile-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  background: var(--primary-light);
  color: var(--primary);
  border-radius: 8rpx;
  font-weight: 600;
}

.profile-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  padding: 8rpx 0;
}

.profile-label {
  font-size: 24rpx;
  color: var(--text-muted);
  flex-shrink: 0;
}

.profile-value {
  font-size: 24rpx;
  color: var(--text);
}

/* 菜单 */
.menu-section {
  background: var(--card-bg);
  margin: 0 24rpx 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(45, 42, 38, 0.05);
}

.menu-title {
  font-size: 22rpx;
  color: var(--text-muted);
  padding: 24rpx 28rpx 10rpx;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 28rpx;
  border-bottom: 1rpx solid var(--divider);
  transition: background 0.15s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--primary-light);
}

.menu-icon {
  font-size: 38rpx;
  margin-right: 22rpx;
  width: 48rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
  font-weight: 500;
}

.menu-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-right: 14rpx;
}

.menu-switch {
  font-size: 22rpx;
  color: var(--text-muted);
  padding: 8rpx 20rpx;
  background: var(--input-bg);
  border-radius: 16rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.menu-switch.on {
  color: #fff;
  background: var(--primary);
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--text-muted);
  opacity: 0.5;
}

/* 存储用量 */
.storage-section {
  background: var(--card-bg);
  margin: 0 24rpx 20rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 42, 38, 0.05);
}

.storage-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 20rpx;
}

/* 危险操作 */
.danger-section {
  padding: 24rpx;
}

.danger-btn {
  text-align: center;
  padding: 26rpx;
  color: var(--text-muted);
  font-size: 26rpx;
  border: 2rpx solid var(--border);
  border-radius: 14rpx;
  transition: all 0.2s ease;
  font-weight: 500;
}

.danger-btn:active {
  color: var(--danger);
  border-color: var(--danger);
  background: var(--danger-light);
}
