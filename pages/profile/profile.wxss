/* 个人中心样式 */
.profile-scroll {
  height: 100vh;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #e4393c 0%, #c1272d 100%);
  margin: 20rpx;
  border-radius: 16rpx;
  color: #fff;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
}

.user-motto {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 快捷统计 */
.quick-stats {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 0 20rpx 20rpx;
  padding: 30rpx;
  border-radius: 12rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.04);
}

.qs-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qs-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #e4393c;
}

.qs-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.qs-divider {
  width: 1rpx;
  height: 50rpx;
  background: #f0f0f0;
}

/* 菜单 */
.menu-section {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.04);
}

.menu-title {
  font-size: 24rpx;
  color: #999;
  padding: 20rpx 24rpx 8rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #fafafa;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.menu-switch {
  font-size: 24rpx;
  color: #999;
  padding: 6rpx 16rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
}

.menu-switch.on {
  color: #fff;
  background: #e4393c;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 存储用量 */
.storage-section {
  background: #fff;
  margin: 0 20rpx 20rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.04);
}

.storage-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

/* 危险操作 */
.danger-section {
  padding: 20rpx;
}

.danger-btn {
  text-align: center;
  padding: 24rpx;
  color: #999;
  font-size: 26rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
}

.danger-btn:active {
  color: #e4393c;
  border-color: #e4393c;
  background: #fef0f0;
}
