/* ===== 周期复盘 v2 — 淡雅暖色设计 ===== */

.content-area {
  padding-bottom: 120rpx;
}

.entry-section {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 42, 38, 0.05);
}

.button-group {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.period-btn {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 36rpx;
  background: var(--input-bg);
  border-radius: 16rpx;
  border: none;
  transition: all 0.2s ease;
}

.period-btn:active {
  background: var(--primary-light);
  transform: scale(0.98);
}

.btn-icon {
  font-size: 52rpx;
  margin-bottom: 18rpx;
}

.period-btn text {
  font-size: 28rpx;
  color: var(--text);
  margin-bottom: 10rpx;
  font-weight: 600;
}

.btn-desc {
  font-size: 24rpx;
  color: var(--text-muted);
}

.history-section {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 42, 38, 0.05);
}

.period-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.period-item {
  padding: 26rpx;
  background: var(--input-bg);
  border-radius: 14rpx;
  transition: all 0.2s ease;
}

.period-item:active {
  background: var(--primary-light);
}

.period-type {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
}

.type-label {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--primary);
}

.date-range {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.analyze-time {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* 周期复盘详情 */
.period-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 22rpx;
  border-bottom: 2rpx solid var(--divider);
  margin-bottom: 28rpx;
}

.included-reviews {
  margin-bottom: 36rpx;
}

.section-label {
  font-size: 28rpx;
  color: var(--text);
  margin-bottom: 18rpx;
  font-weight: 700;
}

.review-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.review-item {
  padding: 18rpx 24rpx;
  background: var(--input-bg);
  border-radius: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.2s ease;
}

.review-item:active {
  background: var(--primary-light);
}

.review-date {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
}

.review-summary {
  font-size: 24rpx;
  color: var(--text-secondary);
  max-width: 60%;
  text-align: right;
}

/* 行为标签分布 */
.tags-section {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 42, 38, 0.05);
}

.tag-list {
  margin-top: 18rpx;
}

.tag-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--divider);
}

.tag-row:last-child {
  border-bottom: none;
}

.tag-name {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--primary);
  min-width: 120rpx;
}

.tag-count {
  font-size: 24rpx;
  color: var(--text-muted);
  min-width: 60rpx;
  font-weight: 500;
}

.tag-bar {
  flex: 1;
  height: 14rpx;
  background: var(--divider);
  border-radius: 7rpx;
  overflow: hidden;
}

.tag-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--primary-dark));
  border-radius: 7rpx;
  transition: width 0.3s ease;
}

/* 计划执行力趋势 */
.trend-section {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 42, 38, 0.05);
}

.trend-list {
  margin-top: 18rpx;
}

.trend-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--divider);
}

.trend-row:last-child {
  border-bottom: none;
}

.trend-row.no-trade {
  opacity: 0.4;
}

.trend-date {
  font-size: 24rpx;
  color: var(--text-secondary);
  min-width: 100rpx;
  font-weight: 500;
}

.trend-none {
  font-size: 24rpx;
  color: var(--text-muted);
}

.trend-data {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.trend-warn {
  font-size: 22rpx;
  min-width: 36rpx;
}

.trend-spacer {
  min-width: 36rpx;
}

.trend-bar-container {
  flex: 1;
  height: 18rpx;
  background: var(--divider);
  border-radius: 9rpx;
  overflow: hidden;
}

.trend-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--primary-dark));
  border-radius: 9rpx;
  min-width: 4rpx;
  transition: width 0.3s ease;
}

.trend-pct {
  font-size: 22rpx;
  color: var(--text-secondary);
  min-width: 140rpx;
  text-align: right;
  font-weight: 500;
}

.trend-summary {
  display: flex;
  justify-content: space-between;
  padding-top: 18rpx;
  margin-top: 18rpx;
  border-top: 2rpx solid var(--divider);
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 500;
}

.analysis-section {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 42, 38, 0.05);
}

/* 加载提示 */
.loading-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 32rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid var(--divider);
  border-top: 3rpx solid var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
