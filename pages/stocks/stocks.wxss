/* ===== 自选股页面 v2 — 淡雅暖色设计 ===== */

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  background: var(--card-bg);
  border-bottom: 1rpx solid var(--divider);
}

.page-title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text);
  letter-spacing: 1rpx;
}

.top-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.refresh-btn {
  font-size: 36rpx;
  transition: transform 0.3s;
  padding: 8rpx;
}

.refresh-btn.spinning {
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.add-btn {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 600;
  padding: 10rpx 24rpx;
  background: var(--primary-light);
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.add-btn:active {
  background: var(--primary);
  color: #fff;
}

/* 搜索面板 */
.search-panel {
  background: var(--card-bg);
  padding: 24rpx;
  border-bottom: 1rpx solid var(--divider);
  animation: slideInUp 0.3s ease;
}

@keyframes slideInUp {
  from { opacity: 0; transform: translateY(-20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.search-box {
  display: flex;
  align-items: center;
  background: var(--input-bg);
  border-radius: 14rpx;
  padding: 18rpx 24rpx;
  gap: 14rpx;
  border: 2rpx solid var(--border);
  transition: border-color 0.2s ease;
}

.search-box:focus-within {
  border-color: var(--primary);
  background: var(--card-bg);
}

.search-icon {
  font-size: 28rpx;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
}

.clear-btn {
  font-size: 28rpx;
  color: var(--text-muted);
  padding: 4rpx 8rpx;
  border-radius: 50%;
  background: var(--divider);
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-results {
  max-height: 600rpx;
  margin-top: 20rpx;
  border-top: 1rpx solid var(--divider);
}

.search-result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 12rpx;
  border-bottom: 1rpx solid var(--divider);
  transition: background 0.15s ease;
}

.search-result-item:active {
  background: var(--primary-light);
}

.result-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.result-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.result-code {
  font-size: 24rpx;
  color: var(--text-muted);
}

.result-type {
  font-size: 20rpx;
  color: var(--info);
  background: var(--info-light);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  align-self: flex-start;
  margin-top: 6rpx;
  font-weight: 500;
}

.result-action {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 600;
  padding: 10rpx 28rpx;
  border: 2rpx solid var(--primary);
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.result-action:active {
  background: var(--primary);
  color: #fff;
}

.result-action.in-list {
  color: var(--text-muted);
  border-color: var(--border);
  background: var(--input-bg);
}

.search-loading, .search-empty {
  text-align: center;
  padding: 40rpx;
  color: var(--text-muted);
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.loading-spinner.mini {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid var(--divider);
  border-top: 3rpx solid var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* 自选股列表 */
.watchlist-area {
  flex: 1;
}

.list-header {
  display: flex;
  padding: 18rpx 28rpx;
  background: var(--input-bg);
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 500;
}

.col-name { flex: 2; }
.col-price { flex: 1.5; text-align: right; }
.col-change { flex: 1.5; text-align: right; }
.col-action { width: 100rpx; text-align: center; }

.stock-card {
  display: flex;
  align-items: center;
  padding: 26rpx 28rpx;
  background: var(--card-bg);
  border-bottom: 1rpx solid var(--divider);
  transition: background 0.15s ease;
}

.stock-card:active {
  background: var(--primary-light);
}

.stock-info {
  flex: 2;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.stock-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.stock-code {
  font-size: 24rpx;
  color: var(--text-muted);
}

.stock-price-area {
  flex: 1.5;
  text-align: right;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.stock-price {
  font-size: 32rpx;
  font-weight: 700;
}

.stock-price.up, .stock-change.up { color: var(--up); }
.stock-price.down, .stock-change.down { color: var(--down); }

.stock-change {
  font-size: 24rpx;
  font-weight: 500;
}

.stock-action {
  width: 100rpx;
  text-align: center;
}

.remove-text {
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 8rpx 18rpx;
  border-radius: 8rpx;
  transition: all 0.2s ease;
}

.remove-text:active {
  color: var(--danger);
  background: var(--danger-light);
}

/* 历史交易股票 */
.traded-section {
  padding: 24rpx;
  margin: 16rpx 0;
  background: var(--card-bg);
  border-radius: 16rpx;
}

.section-label {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 16rpx;
}

.traded-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--divider);
}

.traded-item:last-child {
  border-bottom: none;
}

.traded-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.traded-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
}

.frequent-badge {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  background: var(--warning-light);
  color: var(--warning);
  border-radius: 6rpx;
  font-weight: 600;
}

.traded-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.traded-count {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 600;
}

.traded-last {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 140rpx 40rpx;
  animation: fadeIn 0.5s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.empty-icon {
  font-size: 88rpx;
  margin-bottom: 28rpx;
  opacity: 0.8;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.8;
}

.empty-btn {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 14rpx;
  padding: 0 48rpx;
  height: 88rpx;
  line-height: 88rpx;
  box-shadow: 0 6rpx 20rpx rgba(212, 87, 78, 0.25);
}

.empty-btn::after {
  border: none;
}

.empty-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}
