/* 历史详情页面特有样式 */
.content-area {
  padding-bottom: 140rpx;
}

.review-content {
  margin-top: 16rpx;
}

.review-item {
  margin-bottom: 32rpx;
}

.item-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.item-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
}

.item-subtitle {
  font-size: 24rpx;
  color: #999;
  margin: 16rpx 0 12rpx;
}

/* 交易记录 */
.trade-item {
  padding: 16rpx;
  background: #fafafa;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.trade-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.stock-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.match-plan {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.match-plan.yes {
  background: #fef0f0;
  color: #e4393c;
}

.match-plan.no {
  background: #f5f5f5;
  color: #999;
}

.trade-reason {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 未执行计划 */
.missed-item {
  padding: 16rpx;
  background: #fafafa;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.missed-title {
  font-size: 26rpx;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.missed-reason {
  font-size: 24rpx;
  color: #999;
}

/* 教练追问区 */
.questions-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-left: 4rpx solid #e4393c;
}

.question-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.question-item:last-child {
  border-bottom: none;
}

.question-item.answered {
  opacity: 0.5;
}

.question-content {
  flex: 1;
  display: flex;
  gap: 12rpx;
}

.question-num {
  font-size: 26rpx;
  font-weight: 600;
  color: #e4393c;
}

.question-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  flex: 1;
}

.question-action {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.mark-btn {
  font-size: 24rpx;
  color: #e4393c;
  padding: 8rpx 16rpx;
  background: #fef0f0;
  border-radius: 6rpx;
}

.answered-tag {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.ai-section {
  background: #fff;
}

.footer {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
}

.action-btn.edit {
  background-color: #e4393c;
  color: #fff;
}

.action-btn.share {
  background-color: #1890ff;
  color: #fff;
}

.action-btn.delete {
  background-color: #f5f5f5;
  color: #999;
}
