/* ===== 复盘详情 v2 — 淡雅暖色设计 ===== */

.content-area {
  padding-bottom: 160rpx;
}

.review-content {
  margin-top: 20rpx;
}

.review-item {
  margin-bottom: 36rpx;
}

.item-label {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 14rpx;
  padding-bottom: 14rpx;
  border-bottom: 2rpx solid var(--divider);
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.item-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.9;
  white-space: pre-wrap;
}

.item-subtitle {
  font-size: 24rpx;
  color: var(--text-muted);
  margin: 20rpx 0 14rpx;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

/* 交易记录 */
.trade-item {
  padding: 20rpx;
  background: var(--input-bg);
  border-radius: 14rpx;
  margin-bottom: 14rpx;
  border-left: 4rpx solid var(--border);
  transition: all 0.2s ease;
}

.trade-item:active {
  background: var(--primary-light);
  border-left-color: var(--primary);
}

.trade-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.stock-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
}

.match-plan {
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.match-plan.yes {
  background: var(--success-light);
  color: var(--success);
}

.match-plan.no {
  background: var(--warning-light);
  color: var(--warning);
}

.trade-reason {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

/* 未执行计划 */
.missed-item {
  padding: 20rpx;
  background: var(--warning-light);
  border-radius: 14rpx;
  margin-bottom: 14rpx;
  border-left: 4rpx solid var(--warning);
}

.missed-title {
  font-size: 26rpx;
  color: var(--text);
  display: block;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.missed-reason {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 教练追问区 */
.questions-section {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid var(--primary);
  box-shadow: 0 2rpx 12rpx rgba(45, 42, 38, 0.05);
}

.question-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--divider);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.question-item:last-child {
  border-bottom: none;
}

.question-item.answered {
  opacity: 0.5;
}

.question-content {
  flex: 1;
  display: flex;
  gap: 14rpx;
}

.question-num {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--primary);
  min-width: 40rpx;
}

.question-text {
  font-size: 26rpx;
  color: var(--text);
  line-height: 1.7;
  flex: 1;
}

.question-action {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.mark-btn {
  font-size: 24rpx;
  color: var(--primary);
  padding: 10rpx 20rpx;
  background: var(--primary-light);
  border-radius: 8rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.mark-btn:active {
  background: var(--primary);
  color: #fff;
}

.answered-tag {
  font-size: 22rpx;
  color: var(--success);
  flex-shrink: 0;
  margin-left: 16rpx;
  font-weight: 500;
}

.ai-section {
  background: var(--card-bg);
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(45, 42, 38, 0.05);
}

/* 行为标签 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 12rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 22rpx;
  border-radius: 10rpx;
  background: var(--primary-light);
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 600;
}

.footer {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  padding: 22rpx;
  text-align: center;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  transition: all 0.2s ease;
}

.action-btn.edit {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(212, 87, 78, 0.2);
}

.action-btn.share {
  background: linear-gradient(135deg, var(--info) 0%, #4A7BC4 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(91, 143, 212, 0.2);
}

.action-btn.delete {
  background: var(--input-bg);
  color: var(--text-muted);
}

.action-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}
