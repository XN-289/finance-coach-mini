/* 首页 — 同花顺简约风格 */

/* 导航栏覆盖 */
.nav-bar {
  background-color: #e4393c;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
}

.menu-btn {
  font-size: 44rpx;
  color: #fff;
  padding: 0 10rpx;
}

/* 草稿提示条 */
.draft-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background-color: #fef0f0;
  color: #e4393c;
  font-size: 26rpx;
}

.draft-actions {
  display: flex;
  gap: 20rpx;
}

.draft-action {
  color: #e4393c;
  font-weight: 600;
}

/* 昨日计划追踪卡片 */
.plan-recall-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  margin: 0 20rpx 20rpx;
  border-left: 6rpx solid #e4393c;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

.plan-recall-header {
  margin-bottom: 16rpx;
}

.plan-recall-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #e4393c;
}

.plan-recall-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.plan-recall-item:last-child {
  border-bottom: none;
}

.plan-recall-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 12rpx;
}

.plan-recall-actions {
  display: flex;
  gap: 16rpx;
}

.plan-recall-btn {
  padding: 10rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.plan-recall-btn.triggered {
  background: #fef0f0;
  color: #e4393c;
}

.plan-recall-btn.missed {
  background: #f5f5f5;
  color: #999;
}

.plan-recall-btn:active {
  opacity: 0.7;
}

/* 侧边栏遮罩 */
.drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

/* 侧边栏 */
.drawer {
  position: fixed;
  top: 0;
  right: -600rpx;
  width: 600rpx;
  height: 100vh;
  background-color: #fff;
  z-index: 101;
  transition: right 0.3s ease;
  display: flex;
  flex-direction: column;
}

.drawer.open {
  right: 0;
}

.drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #e8e8e8;
}

.drawer-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.close-btn {
  font-size: 44rpx;
  color: #999;
  padding: 0 20rpx;
}

.drawer-content {
  flex: 1;
  overflow-y: auto;
}

/* 侧边栏区域 */
.period-section, .history-section {
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-label {
  font-size: 26rpx;
  color: #999;
  font-weight: 600;
}

.section-action {
  font-size: 24rpx;
  color: #e4393c;
}

/* 周期复盘 */
.period-item {
  padding: 20rpx;
  background-color: #fafafa;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.period-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #e4393c;
}

.period-date {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 历史列表 */
.history-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.history-main {
  margin-bottom: 12rpx;
}

.history-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.history-summary {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.history-actions {
  display: flex;
  gap: 20rpx;
}

/* 表单区域 */
.form-area {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 140rpx;
}

/* 市场数据卡片（自动获取） */
.market-snapshot {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #e4393c;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

.snapshot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.snapshot-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.snapshot-source {
  font-size: 20rpx;
  color: #ccc;
}

.snapshot-text {
  font-size: 26rpx;
  color: #333;
  line-height: 2;
  white-space: pre-wrap;
}

/* 表单区块 — 统一白卡 */
.form-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

.form-section .section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.form-section .section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  border-left: none;
  padding-left: 0;
  margin-bottom: 0;
}

.title-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: #999;
}

/* 输入组 */
.input-group {
  margin-bottom: 24rpx;
}

.input-label {
  margin-bottom: 12rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 4rpx;
}

.label-tip {
  font-size: 24rpx;
  color: #999;
}

.textarea-input {
  width: 100%;
  min-height: 180rpx;
  padding: 24rpx;
  background-color: #fafafa;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.char-count.small {
  font-size: 20rpx;
}

/* 知行合一 — 分类标题 */
.action-category {
  margin-bottom: 28rpx;
}

.category-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.category-hint {
  font-size: 24rpx;
  color: #999;
}

/* 交易卡片 */
.action-card {
  background: #fff;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #e8e8e8;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  background-color: #fafafa;
}

.card-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
}

.card-content {
  padding: 24rpx;
}

.form-field {
  margin-bottom: 20rpx;
}

.form-field:last-child {
  margin-bottom: 0;
}

.field-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: block;
}

.field-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background-color: #fafafa;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.field-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx 20rpx;
  background-color: #fafafa;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.plan-field {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.switch-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.switch-text {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 600;
}

/* 未执行计划 */
.missed-card {
  background: #fff;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #e8e8e8;
}

.missed-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  background-color: #fafafa;
}

.missed-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
}

.missed-content {
  padding: 24rpx;
}

.missed-field {
  margin-bottom: 20rpx;
}

.missed-field:last-child {
  margin-bottom: 0;
}

.missed-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: block;
}

.missed-input {
  width: 100%;
  min-height: 100rpx;
  padding: 16rpx 20rpx;
  background-color: #fafafa;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 明日计划 */
.plan-example {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background-color: #fafafa;
  border-radius: 8rpx;
  border-left: 4rpx solid #e4393c;
}

.example-label {
  font-size: 22rpx;
  color: #e4393c;
  font-weight: 600;
  margin-right: 8rpx;
}

.example-text {
  font-size: 22rpx;
  color: #666;
}

/* 添加按钮 */
.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 18rpx;
  margin-top: 12rpx;
  background: #fafafa;
  border-radius: 8rpx;
  border: 1rpx dashed #d9d9d9;
  font-size: 26rpx;
  color: #999;
}

.add-btn:active {
  background: #fef0f0;
  border-color: #e4393c;
  color: #e4393c;
}

.add-icon {
  font-size: 28rpx;
  font-weight: 600;
  color: #999;
}

.add-btn:active .add-icon {
  color: #e4393c;
}

/* 删除按钮 */
.delete-btn {
  font-size: 24rpx;
  color: #ccc;
  padding: 8rpx 16rpx;
}

/* 辅助按钮 */
.action-buttons {
  display: flex;
  gap: 12rpx;
}

.action-btn.help-btn,
.action-btn.import-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.action-btn.help-btn {
  background-color: #f0f0f0;
  color: #666;
}

.action-btn.import-btn {
  background-color: #e4393c;
  color: #fff;
}

.action-btn.import-btn::after {
  border: none;
}

/* 对话历史 */
.conversation-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.conversation-item {
  padding: 24rpx;
  background-color: #fafafa;
  border-radius: 8rpx;
}

.conversation-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.conversation-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.conversation-date {
  font-size: 24rpx;
  color: #666;
}

.archived-tag {
  font-size: 22rpx;
  color: #999;
  background-color: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  align-self: flex-start;
}

.conversation-item.archived {
  opacity: 0.5;
}

/* 浮动历史按钮 */
.fab-history {
  position: fixed;
  right: 30rpx;
  bottom: 240rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 100rpx;
  background: #e4393c;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 16rpx rgba(228, 57, 60, 0.4);
  z-index: 50;
}

.fab-history:active {
  transform: scale(0.92);
  opacity: 0.9;
}

.fab-icon {
  font-size: 32rpx;
}

.fab-text {
  font-size: 18rpx;
  color: #fff;
  margin-top: 2rpx;
}

/* 底部按钮 — 首页增强 */
.footer {
  padding: 20rpx 24rpx;
  background: #fff;
  box-shadow: 0 -1rpx 4rpx rgba(0, 0, 0, 0.06);
}

.submit-btn {
  height: 96rpx;
  line-height: 96rpx;
  background-color: #e4393c;
  font-weight: 600;
  border-radius: 8rpx;
}

.submit-btn:active {
  opacity: 0.85;
}
