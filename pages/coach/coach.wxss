/* AI教练页面特有样式 */
.ai-section {
  background: #fff;
}

.ai-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.streaming-badge {
  font-size: 22rpx;
  color: #e4393c;
  padding: 4rpx 12rpx;
  background: #fef0f0;
  border-radius: 12rpx;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.typing-cursor {
  display: inline-block;
  color: #e4393c;
  font-weight: 700;
  animation: blink 0.8s step-end infinite;
  margin-left: 2rpx;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

.loading-text {
  display: block;
  margin-bottom: 30rpx;
  font-weight: 500;
}

.loading-dots {
  display: inline-block;
  animation: dots 1.5s steps(4, end) infinite;
}

@keyframes dots {
  0%, 20% { color: rgba(0,0,0,0); text-shadow: .25em 0 0 rgba(0,0,0,0); }
  40% { color: #999; text-shadow: .25em 0 0 rgba(0,0,0,0); }
  60% { text-shadow: .25em 0 0 rgba(0,0,0,0); }
  80%, 100% { color: #999; text-shadow: -.25em 0 0 rgba(0,0,0,0); }
}

.loading-tip {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 20rpx;
}
