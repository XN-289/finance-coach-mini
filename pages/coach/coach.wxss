/* ===== AI Coach Page — Redesigned ===== */
/* Design: warm, authoritative, wisdom-inspired */

/* ---------- Review Section ---------- */
.review-section {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx var(--shadow);
  border-left: 6rpx solid var(--border);
  position: relative;
}

.review-section .section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.review-section .section-title::before {
  content: '';
  display: inline-block;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--text-secondary);
}

.review-text {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

/* ---------- AI Reply Section ---------- */
.ai-section {
  background: linear-gradient(145deg, var(--card-bg) 0%, var(--primary-light) 100%);
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 32rpx var(--shadow-md);
  border: 2rpx solid rgba(212, 87, 78, 0.08);
  position: relative;
  overflow: hidden;
}

/* Decorative top accent bar */
.ai-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--primary) 0%, var(--primary-dark) 50%, var(--primary) 100%);
  background-size: 200% 100%;
  animation: shimmer 3s ease-in-out infinite;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid var(--divider);
}

.section-header .section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--primary);
  display: flex;
  align-items: center;
  gap: 12rpx;
  letter-spacing: 1rpx;
}

/* Coach icon accent */
.section-header .section-title::before {
  content: '';
  display: inline-block;
  width: 32rpx;
  height: 32rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  opacity: 0.9;
}

.ai-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* Streaming badge with gentle pulse */
.streaming-badge {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--primary);
  padding: 6rpx 18rpx;
  background: var(--primary-light);
  border-radius: 24rpx;
  border: 2rpx solid rgba(212, 87, 78, 0.15);
  animation: stream-pulse 2s ease-in-out infinite;
  letter-spacing: 1rpx;
}

@keyframes stream-pulse {
  0%, 100% {
    opacity: 1;
    box-shadow: 0 0 0 0 rgba(212, 87, 78, 0.2);
  }
  50% {
    opacity: 0.85;
    box-shadow: 0 0 12rpx 4rpx rgba(212, 87, 78, 0.08);
  }
}

/* Copy button */
.copy-btn {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-secondary);
  padding: 6rpx 20rpx;
  background: transparent;
  border: 2rpx solid var(--border);
  border-radius: 24rpx;
  transition: all 0.2s ease;
}

.copy-btn:active {
  color: var(--primary);
  border-color: var(--primary);
  background: var(--primary-light);
}

/* AI reply text */
.ai-text {
  font-size: 30rpx;
  color: var(--text);
  line-height: 2;
  white-space: pre-wrap;
  word-break: break-all;
  letter-spacing: 0.5rpx;
  font-weight: 400;
}

/* AI reply body container */
.ai-reply-body {
  position: relative;
}

/* Typing cursor — smooth blink */
.typing-cursor {
  display: inline-block;
  color: var(--primary);
  font-weight: 300;
  font-size: 32rpx;
  margin-left: 2rpx;
  animation: cursor-blink 1s ease-in-out infinite;
  vertical-align: baseline;
}

@keyframes cursor-blink {
  0%, 100% { opacity: 1; }
  40% { opacity: 1; }
  50% { opacity: 0; }
  90% { opacity: 0; }
}

/* ---------- Loading State ---------- */
.loading {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx var(--shadow);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.loading-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 32rpx;
  display: block;
  letter-spacing: 0.5rpx;
}

.loading-dots {
  display: inline-block;
  animation: dots-flow 1.8s steps(4, end) infinite;
  color: var(--primary);
}

@keyframes dots-flow {
  0%, 20% {
    color: transparent;
    text-shadow: .25em 0 0 transparent, .5em 0 0 transparent;
  }
  40% {
    color: var(--primary);
    text-shadow: .25em 0 0 transparent, .5em 0 0 transparent;
  }
  60% {
    color: var(--primary);
    text-shadow: .25em 0 0 var(--primary), .5em 0 0 transparent;
  }
  80%, 100% {
    color: var(--primary);
    text-shadow: .25em 0 0 var(--primary), .5em 0 0 var(--primary);
  }
}

/* Spinner ring */
.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 6rpx solid var(--border);
  border-top-color: var(--primary);
  animation: spin 0.9s linear infinite;
  margin-bottom: 28rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-tip {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  line-height: 1.5;
  letter-spacing: 0.5rpx;
}

/* ---------- Loading Card (new) ---------- */
.loading-card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 48rpx 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx var(--shadow);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.loading-avatar {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.avatar-emoji {
  font-size: 56rpx;
  z-index: 1;
}

.avatar-pulse {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--primary-light);
  animation: pulse-ring 2s ease-in-out infinite;
}

@keyframes pulse-ring {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.2); opacity: 0.2; }
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.loading-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  letter-spacing: 1rpx;
}

.loading-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.loading-bar {
  width: 200rpx;
  height: 6rpx;
  background: var(--divider);
  border-radius: 3rpx;
  overflow: hidden;
  margin-top: 16rpx;
}

.loading-bar-fill {
  width: 40%;
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--primary-dark));
  border-radius: 3rpx;
  animation: loading-progress 1.5s ease-in-out infinite;
}

@keyframes loading-progress {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(350%); }
}

/* ---------- Error State ---------- */
.error-section {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 48rpx 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx var(--shadow);
  border: 2rpx solid rgba(212, 87, 78, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.error-icon {
  font-size: 56rpx;
  margin-bottom: 20rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-light);
  border-radius: 50%;
}

.error-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 32rpx;
  max-width: 80%;
}

/* Retry button */
.retry-btn {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  border: none;
  border-radius: 40rpx;
  padding: 16rpx 56rpx;
  box-shadow: 0 8rpx 24rpx rgba(212, 87, 78, 0.25);
  letter-spacing: 2rpx;
  transition: all 0.2s ease;
  line-height: 1.6;
}

.retry-btn::after {
  border: none;
}

.retry-btn:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(212, 87, 78, 0.2);
  opacity: 0.9;
}

/* ---------- Agent Phases ---------- */
.agent-phases {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin: 24rpx 0;
  padding: 0 16rpx;
}

.phase-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  opacity: 0.4;
  transition: all 0.3s ease;
}

.phase-item.active {
  opacity: 1;
}

.phase-item.done {
  opacity: 0.8;
}

.phase-icon {
  font-size: 28rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.phase-item.active .phase-icon {
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}

.phase-text {
  font-size: 20rpx;
  color: var(--text-secondary);
  font-weight: 500;
  white-space: nowrap;
}

.phase-item.active .phase-text {
  color: var(--primary);
  font-weight: 600;
}

.phase-line {
  width: 48rpx;
  height: 2rpx;
  background: var(--divider);
  margin: 0 8rpx;
  margin-bottom: 24rpx;
}

/* ---------- Agent Tool Tags ---------- */
.agent-tools-bar {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--divider);
}

.tools-label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-right: 4rpx;
}

.tool-tag {
  font-size: 20rpx;
  color: var(--info);
  background: var(--info-light);
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

/* ---------- Quality Badge ---------- */
.quality-badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.quality-good {
  background: var(--success-light);
  color: var(--success);
}

.quality-fair {
  background: var(--warning-light);
  color: var(--warning);
}

.quality-poor {
  background: var(--primary-light);
  color: var(--primary);
}

/* ---------- Progress Bar ---------- */
.progress-container {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 20rpx 0;
  padding: 0 20rpx;
}

.progress-bar-track {
  flex: 1;
  height: 8rpx;
  background: var(--divider);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--primary-dark));
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-pct {
  font-size: 22rpx;
  color: var(--text-muted);
  min-width: 50rpx;
  text-align: right;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

/* ---------- Milestone ---------- */
.milestone-section {
  background: linear-gradient(135deg, var(--success-light) 0%, var(--card-bg) 100%);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid var(--success);
}

.milestone-item {
  padding: 8rpx 0;
}

.milestone-text {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 600;
}

/* ---------- Action Items ---------- */
.action-items-section {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid var(--divider);
}

.section-sub-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 16rpx;
}

.action-item-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 12rpx 0;
}

.action-item-icon {
  font-size: 26rpx;
  color: var(--primary);
  flex-shrink: 0;
}

.action-item-text {
  font-size: 26rpx;
  color: var(--text);
  line-height: 1.6;
}

/* ---------- Follow-up Questions ---------- */
.followup-section {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--divider);
}

.followup-chip {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: var(--primary-light);
  color: var(--primary);
  border-radius: 24rpx;
  font-size: 24rpx;
  margin: 8rpx 8rpx 0 0;
  font-weight: 500;
}

/* ---------- Promises Section ---------- */
.promises-section {
  background: linear-gradient(135deg, var(--warning-light) 0%, var(--card-bg) 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid var(--warning);
}

.promises-section .section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--warning);
  margin-bottom: 16rpx;
}

.promise-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--divider);
}

.promise-item:last-child { border-bottom: none; }

.promise-text {
  font-size: 26rpx;
  color: var(--text);
  display: block;
  line-height: 1.6;
}

.promise-age {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
  display: block;
}

/* ---------- Feedback Section ---------- */
.feedback-section {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid var(--divider);
}

.feedback-buttons {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.feedback-btn {
  padding: 14rpx 28rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.feedback-btn:active {
  transform: scale(0.95);
}

.feedback-btn.helpful {
  background: var(--success-light);
  color: var(--success);
}

.feedback-btn.not-helpful {
  background: var(--primary-light);
  color: var(--primary);
}

.feedback-btn.too-harsh {
  background: var(--warning-light);
  color: var(--warning);
}

.feedback-btn.too-soft {
  background: var(--info-light);
  color: var(--info);
}

.feedback-thanks {
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 12rpx 0;
  font-style: italic;
}

/* ---------- Reflection Prompts ---------- */
.reflection-section {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--divider);
}

.reflection-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  padding: 10rpx 0;
}

.reflection-icon {
  color: var(--warning);
  font-size: 24rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.reflection-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  font-style: italic;
}

/* ---------- Animations ---------- */
.animate-slideInUp {
  animation: slideInUp 0.4s ease;
}

@keyframes slideInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ---------- Footer ---------- */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--card-bg);
  box-shadow: 0 -4rpx 20rpx var(--shadow);
  z-index: 100;
}

.footer .submit-btn {
  width: 100%;
  height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  border: none;
  border-radius: 44rpx;
  box-shadow: 0 8rpx 28rpx rgba(212, 87, 78, 0.3);
  letter-spacing: 3rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  line-height: 88rpx;
}

.footer .submit-btn::after {
  border: none;
}

.footer .submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(212, 87, 78, 0.2);
  opacity: 0.9;
}
